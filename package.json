{
  "name": "kauppalista-vertailija",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --filter @kauppalista/web dev",
    "dev:api": "bun run --filter @kauppalista/api dev",
    "dev:worker": "bun run --filter @kauppalista/worker dev",
    "build": "bun run --filter '*' build",
    "check": "bun run --filter '*' check",
    "db:migrate": "bun run --filter @kauppalista/db db:migrate",
    "db:seed:test": "bun run --filter @kauppalista/db db:seed:test",
    "test:domain": "bun run --filter @kauppalista/domain test",
    "test:db": "bun run --filter @kauppalista/db test"
  }
}
