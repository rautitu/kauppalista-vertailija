{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@kauppalista/db": ["packages/db/src/index.ts"],
      "@kauppalista/domain": ["packages/domain/src/index.ts"],
      "@kauppalista/engine": ["packages/engine/src/index.ts"],
      "@kauppalista/matcher": ["packages/matcher/src/index.ts"],
      "@kauppalista/searchers": ["packages/searchers/src/index.ts"]
    }
  }
}
